# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase Postgres — connection pooler URL (used by the app at runtime)
# Find in: Supabase Dashboard → Project Settings → Database → Connection string → URI (mode: Transaction)
DATABASE_URL="postgresql://postgres.arzmsjkvwgatpvtssubb:[DB_PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma migrate — bypasses PgBouncer)
# Find in: Supabase Dashboard → Project Settings → Database → Connection string → URI (mode: Session)
DIRECT_URL="postgresql://postgres:[DB_PASSWORD]@db.arzmsjkvwgatpvtssubb.supabase.co:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — always https://<ref>.supabase.co
SUPABASE_URL="https://arzmsjkvwgatpvtssubb.supabase.co"

# Service role key — Project Settings → API → service_role (keep secret, never expose to clients)
SUPABASE_SERVICE_KEY="eyJ..."

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Long random string for signing JWTs
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# Apple Sign In — Bundle ID of your iOS app (e.g. com.yourcompany.crylens)
# Required to verify the audience claim in Apple identity tokens
APPLE_CLIENT_ID="com.yourcompany.crylens"

# Google Sign In — OAuth 2.0 Client ID from Google Cloud Console
# Required to verify Google ID tokens
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
