# PostgreSQL connection string — update host/port/db/user/password for your environment
# For local Docker: docker run --name crylens-pg -e POSTGRES_PASSWORD=secret -e POSTGRES_DB=crylens -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:secret@localhost:5432/crylens?schema=public"

# Secret used to sign JWT tokens — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# Port the HTTP server listens on
PORT=3000

# Environment: development | production | test
NODE_ENV="development"
